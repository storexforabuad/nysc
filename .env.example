# PORT: The port the server will run on.
PORT=3000

# MONNIFY CONFIG
MONNIFY_API_KEY="YOUR_MONNIFY_API_KEY"
MONNIFY_SECRET_KEY="YOUR_MONNIFY_SECRET_KEY"
MONNIFY_CONTRACT_CODE="YOUR_MONNIFY_CONTRACT_CODE"
MONNIFY_BASE_URL="https://api.monnify.com"

# PAYFLEX CONFIG
PAYFLEX_API_KEY="YOUR_PAYFLEX_API_KEY"
PAYFLEX_SECRET_KEY="YOUR_PAYFLEX_SECRET_KEY"
PAYFLEX_BASE_URL="https://api.payflex.ng"

# FIREBASE CONFIG
# This is automatically populated by set_up_firebase in firebase-applet-config.json
# But for local dev or manual override:
# FIREBASE_CREDENTIALS_JSON='{"type": "service_account", ...}'

# APP URL (for webhooks)
APP_URL="https://your-app-url.com"

# MOCK MODE (Bypass API checks)
MOCK_MODE=true

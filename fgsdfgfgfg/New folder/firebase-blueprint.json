{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores co-member onboarding details and bot configuration",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "stateCode": { "type": "string" },
        "state": { "type": "string", "enum": ["START", "AWAITING_NYSC_CODE", "AWAITING_DETAILS", "COMPLETED"] },
        "virtualAccount": {
          "type": "object",
          "properties": {
            "accountNumber": { "type": "string" },
            "bankName": { "type": "string" },
            "accountName": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "state"]
    },
    "DataPlan": {
      "title": "Data Plan",
      "description": "Cached data bundles from Payflex",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "LedgerEntry": {
      "title": "Ledger Entry",
      "description": "Financial records of data vending and commission splits",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "userId": { "type": "string" },
        "buyerPhone": { "type": "string" },
        "planId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "COMPLETED", "FAILED"] },
        "settlement": {
          "type": "object",
          "properties": {
            "coMemberShare": { "type": "number" },
            "systemShare": { "type": "number" },
            "cdsShare": { "type": "number" },
            "totalProfit": { "type": "number" }
          }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/plans_cache/{planId}": {
      "schema": "DataPlan",
      "description": "Cached data plans"
    },
    "/ledger/{entryId}": {
      "schema": "LedgerEntry",
      "description": "Financial ledger"
    }
  }
}
